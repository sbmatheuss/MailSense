# Django
DJANGO_SECRET_KEY=your-secret-key-here-generate-with-python-manage-py-shell
DJANGO_DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DATABASE_URL=postgresql://mailsense:mailsense@postgres:5432/mailsense
POSTGRES_DB=mailsense
POSTGRES_USER=mailsense
POSTGRES_PASSWORD=mailsense

# Redis
REDIS_URL=redis://redis:6379/0

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:80

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Google OAuth2
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/gmail/callback/

